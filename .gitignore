# project-level-ai-rules 用 .gitignore
#
# 注意: このリポジトリは CLAUDE/**/.claude や CURSOR/**/.cursor、
#       CODEX/**/skills にテンプレートを含む。ディレクトリ名「.claude」
#       「.cursor」「skills」単体を
#       無視パターンにしないこと（テンプレが追跡されなくなる）。

# ---------------------------------------------------------------------------
# 機密・環境・ツールのローカル固有
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# Claude Code: マシン／個人差分のみ（テンプレの settings.json は別名で管理）
**/settings.local.json

# Serena（serena_stub.py の docstring 通りローカル専用）
.serena/
serena_stub.py

# ---------------------------------------------------------------------------
# Python（スタブや将来の補助スクリプト用）
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
*.egg-info/
.eggs/
dist/
build/

# ---------------------------------------------------------------------------
# 一時・バックアップ・マージ残骸
# ---------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*.swo
*~
*.orig

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# ---------------------------------------------------------------------------
# エディタ・IDE（個人ワークスペース設定）
# ---------------------------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------------------------
# ログ・調査生成物（リポジトリ外運用を想定）
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# 任意: Node を使う場合
# ---------------------------------------------------------------------------
node_modules/
